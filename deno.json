{
  "tasks": {
    "dev": "deno run --allow-read --allow-net --watch main.tsx",
    "start": "deno run --allow-read --allow-net main.tsx",
    "build": "deno run --allow-read --allow-write --allow-net build.tsx"
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4.0.0",
    "hono/jsx": "jsr:@hono/hono@^4.0.0/jsx",
    "hono/deno": "jsr:@hono/hono@^4.0.0/deno",
    "std/fs": "jsr:@std/fs@^0.224.0",
    "std/path": "jsr:@std/path@^0.224.0",
    "gray-matter": "npm:gray-matter@^4.0.3",
    "marked": "npm:marked@^12.0.0",
    "lucide-react": "npm:lucide-react@^0.368.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  }
}
